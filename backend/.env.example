# Desarrollo local (uvicorn sin Docker). En producción con docker compose, usá el .env de la raíz del repo.
ENVIRONMENT="development"
APP_NAME="NoSignal Survey API"
API_V1_PREFIX="/api/v1"
JWT_SECRET="REEMPLAZAR_CON_SECRETO_LARGO_Y_ALEATORIO"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES=525600
# JSON de usuarios para login MVP. Soporta hash bcrypt o prefijo plain: (temporal).
NOSIGNAL_AUTH_USERS={"admin":"REEMPLAZAR_HASH_BCRYPT"}
# En producción incluir el origen del frontend, p. ej. https://survey.nosignal.site
CORS_ORIGINS=http://localhost:5173
# Opcional: regex si tenés varios orígenes (previews, subdominios). Ej.: https://.*\\.nosignal\\.site
# CORS_ORIGIN_REGEX=
DATABASE_URL="postgresql+asyncpg://nosignal_survey:REEMPLAZAR_PASSWORD@localhost:5434/nosignal_survey"
UPLOAD_ROOT="uploads"
ALLOW_INSECURE_DEFAULTS=true
AUTO_CREATE_SCHEMA=true
# Diagnóstico: logs HTTP con Origin y cabecera CORS en salida (logger nosignal.request).
# Ver también: docker compose logs -f backend
# LOG_LEVEL=debug
# Solo para depurar 500 en el navegador (no dejar en producción pública):
# EXPOSE_ERROR_DETAIL=false

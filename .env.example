# Copia a ".env" en la raíz del repositorio (junto a docker-compose.yml).

# Dominios públicos de PERCENS.
PERCENS_APP_DOMAIN=percens.site
PERCENS_API_DOMAIN=api.percens.site

# Let's Encrypt (Traefik en perfil production).
ACME_EMAIL=admin@percens.site

# Origen del SPA para CORS del backend.
CORS_ORIGINS=https://percens.site

# Secretos de producción.
ENVIRONMENT=production
JWT_SECRET=REEMPLAZAR_CON_SECRETO_PERCENS_LARGO_Y_ALEATORIO
JWT_EXPIRES_MINUTES=525600
POSTGRES_PASSWORD=REEMPLAZAR_PASSWORD_DB_PERCENS
NOSIGNAL_AUTH_USERS={"admin":"REEMPLAZAR_HASH_BCRYPT_PERCENS"}
ALLOW_INSECURE_DEFAULTS=false
AUTO_CREATE_SCHEMA=false

# URL absoluta del API embebida en el build del frontend.
VITE_API_URL=https://api.percens.site

# Opcional: solo si necesitás salirte de la DB local del compose.
# Por defecto el backend usa: postgresql+asyncpg://nosignal_survey:<POSTGRES_PASSWORD>@nosignal-survey-db:5432/nosignal_survey
# SURVEY_DATABASE_URL=postgresql+asyncpg://nosignal_survey:REEMPLAZAR_PASSWORD_DB_PERCENS@nosignal-survey-db:5432/nosignal_survey
